# OpenAI API 配置
# 请复制此文件为 .env 并填入您的实际API密钥

OPENAI_BASE_URL=https://api.deepseek.com/openapi/v1
#OPENAI_BASE_URL=https://api.deepseek.com/openapi/v1/chat/completions
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=DeepSeek-R1


# 或者使用本地兼容服务（如Ollama、vLLM等）
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=sk-1234567890
# OPENAI_MODEL=your-local-model-name

# 使用说明：
# 1. 复制此文件为 .env
# 2. 将 your-openai-api-key-here 替换为您的实际API密钥
# 3. 如果您使用本地服务，请取消注释相应的配置并确保服务已启动